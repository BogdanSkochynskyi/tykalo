# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.
# Docker Compose auto-loads `.env` for variable substitution.

# --- PostgreSQL ---
POSTGRES_DB=tykalo
POSTGRES_USER=tykalo
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Redis ---
# No password for local development. REDIS_HOST is "redis" under Docker Compose,
# "localhost" when running the app directly via ./gradlew bootRun.
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Telegram ---
# Get a token from @BotFather (/newbot). The app fails to start if this is empty.
# See README → "Telegram bot setup (@BotFather)".
TELEGRAM_BOT_TOKEN=
# The bot's public @username (without the @). Used to build t.me/<username>?start=...
# nudger-invite deep-links. Optional, but invite links are broken without it.
TELEGRAM_BOT_USERNAME=

# --- Sentry (optional) ---
# Error tracking in production. Leave empty to disable (the Sentry appender is a
# no-op without a DSN). Only the `prod` profile wires Sentry into logging.
SENTRY_DSN=
